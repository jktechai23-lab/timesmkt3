# ─────────────────────────────────────────────────────────────────────
# CORE — sempre necessárias para rodar o pipeline.
# ─────────────────────────────────────────────────────────────────────

# Anthropic API — usada por todos os agentes via Claude Code CLI (`claude -p`).
# Obrigatória em ambiente Docker (CLI roda headless, sem login interativo).
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Override opcional do endpoint Anthropic. Deixe vazio para api.anthropic.com.
# Aceita OpenRouter (https://openrouter.ai/api/v1), LiteLLM, ou proxy próprio.
# Se setar, ANTHROPIC_API_KEY vira a chave do endpoint escolhido.
# ANTHROPIC_BASE_URL=

TAVILY_API_KEY=tvly-YOUR_API_KEY

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_CHAT_IDS=

# YouTube Data API
# API key — used for public read operations (no auth required)
# Get it from: console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# OAuth 2.0 credentials — required for write operations (upload, update, delete)
# Get them from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
YOUTUBE_CLIENT_ID=YOUR_YOUTUBE_CLIENT_ID
YOUTUBE_CLIENT_SECRET=YOUR_YOUTUBE_CLIENT_SECRET

# Refresh token — obtained after completing the OAuth 2.0 consent flow
# Persists long-term; used to generate new short-lived access tokens
YOUTUBE_REFRESH_TOKEN=YOUR_YOUTUBE_REFRESH_TOKEN

# Instagram Graph API
# Professional Account ID (numeric) — found in Meta Business Suite or via the API
# Endpoint: GET /me?fields=id after authenticating
INSTAGRAM_ACCOUNT_ID=YOUR_INSTAGRAM_PROFESSIONAL_ACCOUNT_ID

# Instagram User Access Token — obtained via Business Login for Instagram or Facebook Login for Business
# Required permissions: instagram_business_basic, instagram_business_content_publish
# Note: long-lived tokens expire after 60 days — refresh before expiry
INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_USER_ACCESS_TOKEN

# Threads API
# User ID — found in the Threads API response or Meta Business Suite
THREADS_USER_ID=YOUR_THREADS_USER_ID

# Threads User Access Token — obtained via the same Facebook Login flow as Instagram
# Required permission: threads_basic, threads_content_publish
# Note: uses graph.threads.net as the API host
THREADS_ACCESS_TOKEN=YOUR_THREADS_ACCESS_TOKEN

# Redis — usado por BullMQ pra fila do pipeline.
#
# Em Docker compose (default): deixe REDIS_URL=redis://redis:6379
#   (resolve pra service name `redis` no network do compose).
#
# Pra Redis externo (Upstash, Redis Cloud), use uma URL completa, ex:
#   REDIS_URL=rediss://default:<senha>@<host>:<porta>
#
# Pra rodar fora de Docker apontando pra localhost:
#   REDIS_URL=redis://localhost:6379
REDIS_URL=redis://redis:6379

# Legado (apenas se REDIS_URL não estiver setado). Evite.
UPSTASH_REDIS_ENDPOINT=
UPSTASH_REDIS_PASSWORD=

# Supabase
# Project URL — found in Supabase dashboard → Settings → API
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL

# Service Role Key — found in Supabase dashboard → Settings → API
# WARNING: This key bypasses Row Level Security. Never expose it client-side.
# Used server-side only for storage uploads from the distribution agent.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Media Providers ────────────────────────────────────────

# Image Generation Provider
# Set to 'kie' (default, pago) or 'pollinations' (gratuito, FLUX Schnell)
IMAGE_PROVIDER=kie
FREE_IMAGE_PROVIDER=pexels

# KIE — z-image, flux-kontext, gpt-image-1
# Get it from: kie.ai → API Keys
KIE_API_KEY=
KIE_DEFAULT_MODEL=z-image

# Pollinations.ai — gratuito, FLUX Schnell / z-image turbo / Gemini / GPT Image
# Sem key funciona (anônimo, 1 req/15s). Com conta Seed free: 1 req/5s, sem watermark.
# Criar conta em: enter.pollinations.ai (sem cartão de crédito)
POLLINATIONS_TOKEN=

# OpenAI — powers both DALL-E 3 image generation and OpenAI TTS
# Get it from: platform.openai.com → API Keys
OPENAI_API_KEY=

# OpenRouter — optional LLM gateway for alternate chat models
# Example aliases for future /model selection (v5 roadmap only):
# qwen36 -> qwen/qwen3.6-plus:free
# qwen35 -> qwen/qwen3.5
# qwen25 -> qwen/qwen2.5
# Use the `OPENROUTER_API_KEY` + `OPENROUTER_BASE_URL` when you want the `/model` switch
# to target OpenRouter (the workflow for v4 stays on Claude until the v5 work is deployed).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_QWEN36=qwen/qwen3.6-plus:free
OPENROUTER_MODEL_QWEN35=qwen/qwen3.5
OPENROUTER_MODEL_QWEN25=qwen/qwen2.5

# Stability AI — Stable Diffusion image generation
# Get it from: platform.stability.ai → API Keys
STABILITY_API_KEY=

# Image Stock (Free)
# Unsplash — free stock photos (requires attribution)
# Get it from: unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Pexels — free stock photos and videos (no attribution required)
# Get it from: pexels.com/api
PEXELS_API_KEY=

# Text-to-Speech / Narration
# ElevenLabs — ultra-realistic AI voices
# Get it from: elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# MiniMax — multilingual TTS
# Get it from: https://platform.minimax.io/user-center/basic-information
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Fish Audio — TTS alternativa (Bella = default, reference_id f18e96e1ed024df98860f6ff60bd6695)
FISH_AUDIO_API_KEY=

# Sound Effects & Music
# Freesound.org — collaborative sound library (CC licensed)
# Get it from: freesound.org/apiv2/apply
FREESOUND_API_KEY=

# Pixabay — free images, video, audio, music
# Get it from: pixabay.com/api/docs
PIXABAY_API_KEY=

# Suno AI — AI music generation
# Get it from: suno.ai
SUNO_API_KEY=

# Piramyd — OpenAI-compatible image API
PIRAMYD_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Runtime / UI
# ─────────────────────────────────────────────────────────────────────

# Porta da UI no host (mapeada do container). Default 5177.
TIMESMKT3_UI_PORT=5177

# Ambiente. Use "production" em VPS, "development" pra dev local.
NODE_ENV=production
